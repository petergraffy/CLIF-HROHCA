# R specific gitignores
.Rprofile
.Rhistory
.Rprofile
.Ruserdata
.DS_Store
*.Rproj
.Rproj.user

## ignore the renv initialization file
initialize_renv.R

## ignore filtered CLIF tables stored as Rdata
*.RData

#ignore source CLIF_ files 
CLIF_*.parquet
CLIF_*.csv
CLIF_*.fst
!reference/clif_hospital_geography.csv

#ignore the identifier app
CLIF_cohort_identifier*

# ignore file used to initialize renv when creating the template
initialize_renv.R

# ignore filtered CLIF tables stored as Rdata
*.RData

# ignore pdf reports and rendered html
*.pdf
*.html

# ignore large Daymet intermediate files
output/intermediate/daymet/raw/
*.nc

# Local package/runtime caches
.r-user-lib/
.vendor-py/
.mplconfig/

# Never commit generated analysis outputs or CLIF-derived intermediates.
output/

# Historical exploratory scripts and one-off data build utilities.
archive_nonessential/
code/daymet/

# Python/cache artifacts are not part of the site-runnable R workflow.
__pycache__/
*.pyc
